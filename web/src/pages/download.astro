---
import BaseLayout from '../layouts/BaseLayout.astro';
import DownloadButtons from '../components/DownloadButtons.astro';
---

<BaseLayout
  title="Download"
  description="Download Morning Alarm for iOS and Android. Free with optional Premium upgrade for the full scene, melody, and meditation library."
  canonicalPath="/download"
>
  <div class="max-w-3xl mx-auto px-6 pt-16 pb-20 text-center">
    <h1 class="text-4xl font-bold mb-4">Download Morning Alarm</h1>
    <p class="text-lg text-morning-on-bg/60 mb-12 max-w-xl mx-auto">
      Free to download. Wake up to atmosphere on iOS or Android.
    </p>

    <DownloadButtons centered large />

    <!-- System requirements -->
    <div class="mt-16 grid sm:grid-cols-2 gap-6 text-left">
      <div class="bg-white/60 rounded-2xl p-6 border border-morning-outline-variant/30">
        <h3 class="font-semibold mb-3 flex items-center gap-2">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          iOS
        </h3>
        <ul class="text-sm text-morning-on-bg/60 space-y-1">
          <li>iOS 16.0 or later</li>
          <li>iPhone and iPad</li>
          <li>~50 MB download</li>
        </ul>
      </div>
      <div class="bg-white/60 rounded-2xl p-6 border border-morning-outline-variant/30">
        <h3 class="font-semibold mb-3 flex items-center gap-2">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M3 20.5v-17c0-.59.34-1.11.84-1.35L13.69 12l-9.85 9.85c-.5-.24-.84-.76-.84-1.35m13.81-5.38L6.05 21.34l8.49-8.49 2.27 2.27m3.35-4.31c.34.27.56.69.56 1.19s-.22.92-.56 1.19l-2.29 1.32-2.5-2.5 2.5-2.5 2.29 1.3M6.05 2.66l10.76 6.22-2.27 2.27-8.49-8.49z"/>
          </svg>
          Android
        </h3>
        <ul class="text-sm text-morning-on-bg/60 space-y-1">
          <li>Android 8.0 (API 26) or later</li>
          <li>Phone and tablet</li>
          <li>~40 MB download</li>
        </ul>
      </div>
    </div>

    <!-- Pricing note -->
    <div class="mt-12 bg-morning-brand/10 rounded-2xl p-6">
      <h3 class="font-semibold mb-2">Free & Premium</h3>
      <p class="text-sm text-morning-on-bg/60 max-w-lg mx-auto">
        Morning Alarm is free with a curated set of scenes and melodies. Premium unlocks the full library — all scenes, meditations, ambient sounds, and voice-stop control.
      </p>
    </div>
  </div>
</BaseLayout>
