---
import { site } from '../data/site';
import DownloadButtons from './DownloadButtons.astro';
---

<section class="relative overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-gradient-to-br from-morning-brand/20 via-morning-bg to-night-primary/10" />
    <div class="absolute top-20 -right-32 w-96 h-96 bg-morning-brand/15 rounded-full blur-3xl" />
    <div class="absolute -bottom-20 -left-32 w-80 h-80 bg-night-primary/10 rounded-full blur-3xl" />
  </div>

  <div class="max-w-5xl mx-auto px-6 pt-24 pb-20 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 rounded-full bg-morning-brand/15 px-4 py-1.5 text-sm font-medium text-morning-primary mb-8">
      <span>☀</span>
      <span>Morning & Night modes</span>
      <span>🌙</span>
    </div>

    <!-- Headline -->
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-morning-on-bg max-w-3xl mx-auto leading-tight">
      Wake up to
      <span class="text-morning-primary"> atmosphere</span>,
      not noise
    </h1>

    <!-- Subheadline -->
    <p class="mt-6 text-lg sm:text-xl text-morning-on-bg/60 max-w-2xl mx-auto leading-relaxed">
      {site.description}
    </p>

    <!-- CTA -->
    <div class="mt-10">
      <DownloadButtons centered />
    </div>
  </div>
</section>
