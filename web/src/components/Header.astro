---
import { site } from '../data/site';

const navLinks = [
  { href: '/features', label: 'Features' },
  { href: '/screenshots', label: 'Screenshots' },
  { href: '/faq', label: 'FAQ' },
  { href: '/download', label: 'Download' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-morning-bg/80 backdrop-blur-lg border-b border-morning-outline-variant/30">
  <nav class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 font-semibold text-lg text-morning-on-bg hover:text-morning-primary transition-colors">
      <span class="text-2xl">☀</span>
      <span>{site.name}</span>
    </a>

    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'text-sm font-medium transition-colors',
              currentPath === href
                ? 'text-morning-primary'
                : 'text-morning-on-bg/70 hover:text-morning-primary',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-morning-on-bg/70 hover:text-morning-primary"
      aria-label="Open menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-morning-outline-variant/30 bg-morning-bg">
    <ul class="px-6 py-4 space-y-3">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'block text-sm font-medium transition-colors',
              currentPath === href
                ? 'text-morning-primary'
                : 'text-morning-on-bg/70 hover:text-morning-primary',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
