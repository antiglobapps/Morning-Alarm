---
import { site } from '../data/site';
---

<footer class="border-t border-morning-outline-variant/30 mt-24">
  <div class="max-w-5xl mx-auto px-6 py-12">
    <div class="flex flex-col md:flex-row justify-between items-start gap-8">
      <!-- Brand -->
      <div>
        <a href="/" class="flex items-center gap-2 font-semibold text-lg text-morning-on-bg">
          <span class="text-2xl">☀</span>
          <span>{site.name}</span>
        </a>
        <p class="mt-2 text-sm text-morning-on-bg/60 max-w-xs">
          {site.tagline}
        </p>
      </div>

      <!-- Links -->
      <div class="flex gap-16">
        <div>
          <h4 class="text-xs font-semibold uppercase tracking-wider text-morning-on-bg/40 mb-3">Product</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="/features" class="text-morning-on-bg/70 hover:text-morning-primary transition-colors">Features</a></li>
            <li><a href="/screenshots" class="text-morning-on-bg/70 hover:text-morning-primary transition-colors">Screenshots</a></li>
            <li><a href="/download" class="text-morning-on-bg/70 hover:text-morning-primary transition-colors">Download</a></li>
            <li><a href="/faq" class="text-morning-on-bg/70 hover:text-morning-primary transition-colors">FAQ</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-xs font-semibold uppercase tracking-wider text-morning-on-bg/40 mb-3">Legal</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="/privacy" class="text-morning-on-bg/70 hover:text-morning-primary transition-colors">Privacy Policy</a></li>
            <li><a href="/terms" class="text-morning-on-bg/70 hover:text-morning-primary transition-colors">Terms of Service</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="mt-12 pt-6 border-t border-morning-outline-variant/20 text-xs text-morning-on-bg/40">
      {site.copyright}. All rights reserved.
    </div>
  </div>
</footer>
